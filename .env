# Symfony loads these files in order (later overrides earlier):
#  .env               → default values (this file, committed)
#  .env.local         → local overrides (NOT committed)
#  .env.$APP_ENV      → environment-specific defaults (committed)
#  .env.$APP_ENV.local → environment + local overrides (NOT committed)
#
# DO NOT store production secrets here.

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=change-me
###< symfony/framework-bundle ###

###> authorization ###
AUTH_TOKEN=change-me
###< authorization ###

###> doctrine/doctrine-bundle ###
DATABASE_URL="postgresql://symfony:symfony@db:5432/symfony_hex_template?serverVersion=16&charset=utf8"
###< doctrine/doctrine-bundle ###

###> symfony/messenger ###
RABBITMQ_DSN=amqp://admin:admin123@rabbitmq:5672/%2f/async_events
###< symfony/messenger ###
